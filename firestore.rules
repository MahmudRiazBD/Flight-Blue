
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // In a real app with custom claims: return request.auth.token.role in ['admin', 'superadmin'];
      // Simplified for this context as custom claims setup is not available.
      // This relies on Firestore user document data, which is less secure/performant.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }
    
    // Publicly readable collections
    match /packages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /destinations/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /packageTypes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
       allow read: if true;
       allow write: if isAdmin();
    }

    // User data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
      // Allow admins to list users
      allow list: if isAdmin();
    }

    // Private collections
     match /bookings/{docId} {
      allow read, write: if isAdmin();
      // Add rule for users to read their own bookings later
    }

    match /contactMessages/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
