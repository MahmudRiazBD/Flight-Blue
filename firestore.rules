
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an admin or superadmin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    // Settings: Public can read, only admins can write.
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Packages, Destinations, Types: Public can read, only admins can write.
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /destinations/{destinationId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /packageTypes/{typeId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Blog Posts and Categories: Public can read, only admins can write.
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
     match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users:
    // - Authenticated users can read their own data.
    // - Admins can read any user's data.
    // - Authenticated users can update their own data.
    // - Admins can update any user's data (except another superadmin's role).
    // - Only admins can create or delete users (via backend functions which this rule allows).
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow update: if request.auth.uid == userId || (isAdmin() && resource.data.role != 'superadmin');
      allow create, delete: if isAdmin();
    }

    // Bookings and Messages: Only admins can read/write.
    // This assumes customers don't see their own bookings on a separate page yet.
    // If they do, this rule will need to be adjusted.
    match /bookings/{bookingId} {
        allow read, write: if isAdmin();
        // To allow users to create their own booking:
        allow create: if request.auth != null;
    }
     match /contactMessages/{messageId} {
      allow read, write: if isAdmin();
      // Allow anyone to create a contact message
      allow create: if true;
    }
  }
}
