rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for admin roles
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    // PUBLIC READABLE COLLECTIONS
    // Anyone can read, but only admins can write.
    match /{collection}/{docId} where collection in ['packages', 'posts', 'categories', 'destinations', 'packageTypes', 'settings'] {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // USERS COLLECTION
    // Users can create their own account.
    // They can only read/update their own document.
    // Admins can read/update any user document.
    match /users/{userId} {
      allow create: if request.auth != null;
      allow read, update: if (request.auth != null && request.auth.uid == userId) || (request.auth != null && isAdmin());
      // Deletion should be handled by a backend function for safety, but for now allow admins.
      allow delete: if request.auth != null && isAdmin();
    }

    // BOOKINGS & MESSAGES
    // Anyone can create (submit a form).
    // Only admins can read, update, or delete them.
    match /{collection}/{docId} where collection in ['bookings', 'contactMessages'] {
      allow create: if true;
      allow read, update, delete: if request.auth != null && isAdmin();
    }
  }
}
