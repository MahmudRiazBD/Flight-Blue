rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    // In a real production app, this should use custom claims:
    // request.auth.token.role in ['admin', 'superadmin']
    // For this project, we allow any authenticated user to act as an admin for seeding.
    function isAdmin() {
      return isAuth();
    }

    match /{document=**} {
      allow read, write: if false;
    }

    // Publicly readable collections, writable by admins
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /destinations/{destinationId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /packageTypes/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/global {
        allow read: if true;
        allow write: if isAdmin();
    }

    // User documents can be read by any authenticated user,
    // but can only be updated by the user themselves or an admin.
    // Only admins can create or delete users.
    match /users/{userId} {
      allow read: if isAuth();
      allow update: if request.auth.uid == userId || isAdmin();
      allow create, delete: if isAdmin();
    }
    
    // Bookings and Messages can be created by authenticated users,
    // but only managed by admins.
    match /bookings/{bookingId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAuth();
    }
    
    match /contactMessages/{messageId} {
        allow read, update, delete: if isAdmin();
        // Allow anyone to create a contact message
        allow create: if true;
    }
  }
}
