rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for admin roles
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'staff'];
    }

    // Default deny all access to all documents
    match /{document=**} {
      allow read, write: if false;
    }
    
    // USERS collection
    // Admins can read/write any user.
    // Authenticated users can read/update their own profile, but not change their role.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth != null;
    }

    // Public collections: Allow public read, but only admin write.
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /destinations/{destinationId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /packageTypes/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Settings collections: Public read, admin write
    match /settings/{settingId} {
        allow read: if true;
        allow write: if isAdmin();
    }
    
    // Bookings collection
    // Authenticated users can create bookings.
    // Admins can read/write all bookings.
    match /bookings/{bookingId} {
      allow create: if request.auth != null;
      allow read, write: if isAdmin();
    }
    
    // Contact Messages collection
    // Anyone can create a contact message (submit the form).
    // Admins can read/write all messages.
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
