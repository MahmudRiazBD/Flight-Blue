
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isSuperAdmin() {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isStaff() {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    function isAdminOrSuperAdmin() {
      return isAdmin() || isSuperAdmin();
    }
    
    function isStaffOrAdminOrSuperAdmin() {
      return isStaff() || isAdmin() || isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isUser(userId) || isAdminOrSuperAdmin();
      allow update: if isUser(userId) || isAdminOrSuperAdmin();
      allow delete: if isAdminOrSuperAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow create, update, delete: if isStaffOrAdminOrSuperAdmin();
    }

    match /destinations/{destinationId} {
      allow read: if true;
      allow create, update, delete: if isStaffOrAdminOrSuperAdmin();
    }

    match /packageTypes/{typeId} {
      allow read: if true;
      allow create, update, delete: if isStaffOrAdminOrSuperAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isStaffOrAdminOrSuperAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isStaffOrAdminOrSuperAdmin();
    }
    
    match /pages/{pageId} {
      allow read: if true;
      allow create, update, delete: if isStaffOrAdminOrSuperAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if request.auth != null; // Only logged-in users can see their bookings
      allow create: if request.auth != null; // Only logged-in users can create bookings
      allow update, delete: if isStaffOrAdminOrSuperAdmin();
    }

    match /contactMessages/{messageId} {
      allow read, update, delete: if isStaffOrAdminOrSuperAdmin();
      allow create: if true; // Anyone can send a message
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdminOrSuperAdmin();
    }
  }
}
