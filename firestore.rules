
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny all writes, allow all reads for public collections
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow any user to create their own user document.
      // Security is enforced by the application logic ensuring the UID matches.
      allow create: if true;
      
      // Users can only read and update their own documents.
      allow read, update: if request.auth != null && request.auth.uid == userId;

      // Deletion is handled by a server-side action, so client-side delete is disallowed for non-admins.
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    // Rules for collections that require admin/staff write access
    function isStaffOrAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['staff', 'admin', 'superadmin'];
    }

    match /bookings/{bookingId} {
      allow create, update: if isStaffOrAdmin();
    }

    match /categories/{categoryId} {
      allow write: if isStaffOrAdmin();
    }
    
    match /destinations/{destinationId} {
      allow write: if isStaffOrAdmin();
    }
    
    match /packageTypes/{typeId} {
        allow write: if isStaffOrAdmin();
    }

    match /packages/{packageId} {
      allow write: if isStaffOrAdmin();
    }
    
    match /posts/{postId} {
        allow write: if isStaffOrAdmin();
    }

    match /pages/{pageId} {
        allow write: if isStaffOrAdmin();
    }
    
    match /media/{mediaId} {
        allow write: if isStaffOrAdmin();
    }
    
    match /settings/{settingId} {
        allow write: if isStaffOrAdmin();
    }

    // Rules for contact messages - allow anyone to create one.
    match /contactMessages/{messageId} {
        allow create: if true;
        allow read, update, delete: if isStaffOrAdmin();
    }
  }
}
