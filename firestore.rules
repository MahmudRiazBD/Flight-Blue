
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Check if the user is authenticated and their role is one of the admin types.
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'staff'];
    }

    function isOwner(userId) {
      // Check if the authenticated user is the owner of the document.
      return request.auth != null && request.auth.uid == userId;
    }

    // Public collections, readable by anyone.
    // Writable only by admins.
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /destinations/{destId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /packageTypes/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /pages/{pageId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Settings should be readable by anyone for site configuration.
    match /settings/{settingId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // User profiles can be read by anyone (for author names, etc.)
    // but can only be created/updated by the owner or an admin.
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId); // User can create their own document on signup.
      // User can update their own profile but cannot change their own role.
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin(); // Only admins can delete users.
    }

    // Bookings can be created by authenticated users, but only managed by admins.
    match /bookings/{bookingId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null;
    }

    // Anyone can send a message, but only admins can read/manage them.
    match /contactMessages/{messageId} {
        allow read, write: if isAdmin();
        allow create: if true;
    }
  }
}
